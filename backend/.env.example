# ==========================================
# KPI Dashboard — Backend Environment Variables
# ==========================================
# Bu dosyayı .env olarak kopyala ve değerleri doldur:
# cp .env.example .env

# ------------------------------------------
# Sunucu
# ------------------------------------------
NODE_ENV=development
PORT=3001

# ------------------------------------------
# MySQL Veritabanı
# ------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=kpi_dashboard
DB_USER=root
DB_PASSWORD=your_password_here

# ------------------------------------------
# JWT
# ------------------------------------------
JWT_ACCESS_SECRET=your_super_secret_access_key_here_change_this
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_this
JWT_ACCESS_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ------------------------------------------
# Rate Limiting
# ------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------
# Upload
# ------------------------------------------
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=uploads

# ------------------------------------------
# KPI Cache TTL (dakika)
# ------------------------------------------
KPI_CACHE_TTL_MINUTES=15

# ------------------------------------------
# CORS — Frontend origin
# ------------------------------------------
CORS_ORIGIN=http://localhost:5173
